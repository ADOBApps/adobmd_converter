  "license": {
    "type": "free",
    "max_activations": 50
  },
  "config": {
    "default_bond_cutoff": 1.2,
    "auto_detect_bonds": true,
    "default_box_size": 50.0,
    "qm_region_by_molecule": false,
    "qm_region_file": "qm_region.txt"
  }
